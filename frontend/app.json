{
  "expo": {
    "name": "PropSignal Engine",
    "slug": "propsignal-engine",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "propsignal",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "extra": {
      "eas": {
        "projectId": "propsignal-engine-2026"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.propsignal.engine",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Receive alerts for BUY/SELL trading signals"
      }
    },
    "android": {
      "package": "com.propsignal.engine",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#00ff88"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
