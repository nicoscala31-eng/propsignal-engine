# PropSignal Engine - Production Environment Variables for Railway
# Copy these to Railway's environment variables section

# ======================
# REQUIRED - Database
# ======================
# Railway MongoDB addon will auto-set this, OR use MongoDB Atlas:
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/propsignal?retryWrites=true&w=majority
DB_NAME=propsignal

# ======================
# REQUIRED - Market Data
# ======================
# Get your key from: https://twelvedata.com/apikey
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# ======================
# OPTIONAL - Server Config
# ======================
# Railway sets PORT automatically
# PORT=8001

# ======================
# NOTES
# ======================
# 1. Railway automatically provides PORT
# 2. For MongoDB, either use Railway's MongoDB addon OR MongoDB Atlas
# 3. Twelve Data free tier: 800 API credits/day, 8/min
# 4. Consider upgrading to Twelve Data paid plan for production use
